    pg_pin (VNW) {
      voltage_name : VNW;
      pg_type : nwell;
      physical_connection : device_layer;
    }
    pg_pin (VDD) {
      voltage_name : VDD;
      related_bias_pin : VNW;
      pg_type : primary_power;
    }
    pg_pin (VSS) {
      voltage_name : VSS;
      related_bias_pin : VPW;
      pg_type : primary_ground;
    }
  }
}
